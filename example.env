# ArchieMate environment variables
# Copy this file to .env and fill in the values before running docker compose.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://postgres:5432/archiemate
DATABASE_USER=archiemate
DATABASE_PASSWORD=archiemate

# JWT signing
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_TOKEN_LIFETIME_MINUTES=15

# Logging
LOG_LEVEL=INFO

# Ask timeout (Pekko ask pattern default)
ASK_TIMEOUT=5s

# Admin access (Twitch user ID)
ADMIN_USER_ID=

# OAuth callback
CALLBACK_BASE_URL=http://localhost

# Twitch OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CALLBACK_PATH=/auth/twitch/callback
