# ArchieMate environment variables
# Copy this file to .env and fill in the values before running docker compose.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://postgres:5432/archiemate
DATABASE_USER=archiemate
DATABASE_PASSWORD=archiemate

# JWT signing
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_TOKEN_LIFETIME_MINUTES=15

# Twitch OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI_POSTFIX=/auth/twitch/callback
